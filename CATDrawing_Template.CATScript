Sub CATMain()
	CATInit
  	On Error Resume Next
   	name = DrwTexts.GetItem("Reference_" + MacroID).Name
' msgbox MacroID
   	If Err.Number <> 0 Then
     	Err.Clear
     	name = Text_26
	End If
  	On Error Goto 0
  	If (name = Text_26) Then
    	CATDrw_Create
  	Else   
    	ReDimension
  	End If
End Sub

Sub CATDrw_Create()
  '-------------------------------------------------------------------------------
  ' Création du cadre et du cartouche
  '-------------------------------------------------------------------------------
  CATInit       ' Pour initialiser les variables publiques & travailler dans la vue "background"
  If CATCheckLink = False then
    InitialView.Activate
    Exit Sub
  End If
  If CATCheckRef(1) Then 
    InitialView.Activate
    Exit Sub           ' si un cartouche existe déjà il sera remis a jour
  End If


  CATStandard   ' Pour calculer les valeurs standard

  CATReference  ' Pour placer sur le dessin un texte de reference

  CATFrame      ' Pour dessiner un cadre

  CATTitleBlock ' Pour dessiner le cartouche et le remplir
End Sub

Sub CATDrw_Delete()
  '-------------------------------------------------------------------------------
  ' Effacement du cartouche
  '-------------------------------------------------------------------------------
  CATInit
  If CATCheckLink = False then
    InitialView.Activate
    Exit Sub
  End If
  If CATCheckRef(0) Then
    InitialView.Activate
    Exit Sub
  End If
  CATRemoveAll
End Sub

Sub CATDrw_Modify()
  '-------------------------------------------------------------------------------
  'How to create or modify a revison block
  '-------------------------------------------------------------------------------
  Dim X As double
  Dim Y As double
  CATInit
  If CATCheckLink = False then
    InitialView.Activate
    Exit Sub
  End If
  If CATCheckRef(0) Then
    InitialView.Activate
    Exit Sub
  End If
  revision = CATCheckRev
  On Error Resume Next
   DrwTexts.GetItem("TitleBlock_Text_MDate_" + Chr(65 + revision)).Text = Date
   If Err.Number <> 0 Then
     Err.Clear
   End If
  On Error Goto 0
  CATStandard                  ' Pour calculer les valeurs standard
  revision = CATCheckRev
  Description = InputBox( Message_8)',Message_9, Message_10)
  if Description = "" or Description = Message_10 then
        exit sub
  end if
  CATRevisionBlock
  CATRevisionBlockText(Description) 
End Sub

Sub ReDimension()
  '-------------------------------------------------------------------------------
  ' Redimensionnement du cadre
  '-------------------------------------------------------------------------------
  CATInit
  If CATCheckLink = False then
    InitialView.Activate
    Exit Sub
  End If

  If CATCheckRef(0) Then
    InitialView.Activate
    Exit Sub
  End If
  CATStandard
  CATMoveReference
  If TranslationX <> 0 Or TranslationY <> 0 Then
    CATRemoveStandard
    CATMoveTitleBlock
    CATRemoveFrame
    CATFrame
    CATTitleBlockFrame
    CATTitleBlockStandard
    rev = CATCheckRev
    For i = 0 To rev-1
      revision = i 
      CATRevisionBlock
    Next 
  End If
  CATLinks
End Sub

Sub CATInit()
  '-------------------------------------------------------------------------------
  ' Initialisation du dialogue et creation des objets principaux
  '-------------------------------------------------------------------------------
  Set documents1  = CATIA.Documents
  Set DrwDocument = CATIA.ActiveDocument
  Set DrwSheets   = DrwDocument.Sheets
  Set Selection   = DrwDocument.Selection
  Set DrwSheet    = DrwSheets.ActiveSheet
  Set InitialView = DrwSheet.Views.ActiveView
  Set DrwView     = DrwSheet.Views.Item(2)
  DrwView.Activate
  Set Parameters1 = DrwDocument.Parameters
  Set DrwTexts    = DrwView.Texts
  Set Fact        = DrwView.Factory2D
  Set GeomElems   = DrwView.GeometricElements
  Set Tableaux    = DrwView.Tables
End Sub

Sub CATStandard()
  '-------------------------------------------------------------------------------
  'How to compute standard values
  '-------------------------------------------------------------------------------
  Hauteur      = DrwSheet.GetPaperHeight
  Largeur      = DrwSheet.GetPaperWidth
  sheetFormat  = DrwSheet.PaperSize

  Marge = 10  'Marge par defaut de 10.
  If (sheetFormat = CatPaperA0 Or sheetFormat = CatPaperA1 Or sheetFormat = CatPaperUser And _
      (DrwSheet.GetPaperWidth > 594 Or DrwSheet.GetPaperHeight > 594)) Then
    Marge = 10
  End If

  OH = Largeur - Marge
  OV = Marge

  documentStd = DrwDocument.Standard
  If (documentStd = catISO) Then
    If sheetFormat = 13 Then
      displayFormat = "USER"
    Else
      displayFormat = "A" + CStr(sheetFormat - 2)
    End If
  Else
    Select Case sheetFormat
      Case 0
        displayFormat = "Letter"
      Case 1
        displayFormat = "Legal"
      Case 7 
        displayFormat = "A"
      Case 8 
        displayFormat = "B"
      Case 9 
        displayFormat = "C"
      Case 10 
        displayFormat = "D"
      Case 11 
        displayFormat = "E"
      Case 12 
        displayFormat = "F"
      Case 13 
        displayFormat = "J"
    End Select 
  End If
End Sub


Sub CATReference()
  '-------------------------------------------------------------------------------
  'How to create a reference text (en haut à droite)
  '-------------------------------------------------------------------------------
  Set Text = DrwTexts.Add("", Largeur - Marge, Hauteur - Marge)
  Text.Name = "Reference_" + MacroID
End Sub


Function GetDrawingParameter(ParameterName As String, Value as String, ParamCollection as Parameters) As Parameter
'Dim TempParam as Parameter

On Error Resume Next
	Set TempParam = ParamCollection.Item(ParameterName)
	If TempParam is Nothing then
		Set   GetDrawingParameter   = ParamCollection.CreateString(ParameterName,Value)
	Else
		Set GetDrawingParameter  = TempParam
	End If

On error Goto 0
End Function 


Function CATCheckRef(Mode As Integer) As Integer
  '-------------------------------------------------------------------------------
  'How to check that the called macro is the right one
  '-------------------------------------------------------------------------------
  nbTexts = DrwTexts.Count
  i = 0
  notFound = 0
  While (notFound = 0 And i<nbTexts)
    i = i + 1    
    Set Text = DrwTexts.Item(i)
    WholeName = Text.Name
    leftText = Left(WholeName, 10)
    If (leftText = "Reference_") Then
      notFound = 1
      refText = "Reference_" + MacroID
      If (Mode = 1) Then 
        MsgBox Message_1
        CATCheckRef = 1
        ReDimension
        Exit Function
      ElseIf (Text.Name <> refText) Then
        MsgBox Message_2 + Chr(10) + "        " + MacroID
        CATCheckRef = 1
        Exit Function
      End If
    End If
  Wend
  CATCheckRef = 0
End Function

Function CATCheckLink() As Boolean
  '-------------------------------------------------------------------------------
  ' Verif de l'existence d'une vue et d'un lien enregistré
  '-------------------------------------------------------------------------------

  CATCheckLink = True
  On Error Resume Next
    Err.Clear
    If DrwSheet.Views.Count < 3 Then
	MsgBox(Message_3)
      CATCheckLink = False
      Exit Function
    End If
    Set ProductDrawn = DrwSheet.Views.Item(3).GenerativeBehavior.Document

    If Err.Number <> 0 Then
      MsgBox(Message_4)
	CATCheckLink = False
      Exit Function
  '  Else
  '-------------------------------------------------------------------------------------------------------------------
  ' Si un lien existe avec un document 3D, on vérifie si ce fichier est bien sauvegardé dans le work de SmarTeam
 ' If a link exists with a document 3D, they prove if this file is safeguarded well in the work of SmarTeam
  '-------------------------------------------------------------------------------------------------------------------

 '  If ProductDrawn.Parent.Saved = False Then
 '       Reponse = MsgBox(Message_5 , vbCritical, Message_7)
 '       CATCheckLink = False
 '       Exit Function
 '     End If
    End If
  On Error Goto 0
End Function

Function Cmoy(i1 As Integer,i2 As Integer) As Double
' Cette fonction calcule la position moyenne entre 2 colonnes simplement à partir du numéro des colonnes
' This function calculates medium position between 2 columns simply from the number of columns
  Cmoy = (2*OH +col(i1) + col(i2) )/2
End Function


Function Lmoy(j1 As Integer,j2 As Integer) As Double
' Cette fonction calcule la position moyenne entre 2 lignes simplement à partir du numéro des lignes
' This function calculates medium position between 2 lines simply from the number of lines
  Lmoy = (2*OV + row(j1) + row(j2) )/2
End Function


Function CATCheckRev() As Integer
  '-------------------------------------------------------------------------------
  'How to check that a revision block alredy exists
  '-------------------------------------------------------------------------------
  CATCheckRev = 0
  nbTexts = DrwTexts.Count
  i = 0
  While (i<nbTexts)
    current = 0
    i = i + 1
    Set Text = DrwTexts.Item(i)
    WholeName = Text.Name
    leftText = Left(WholeName, 23)
    If (leftText = "RevisionBlock_Text_Rev_") Then 
      CATCheckRev = CATCheckRev + 1
    End If
  Wend

End Function


Sub CATTitleBlock()
  '-------------------------------------------------------------------------------
  'How to create the TitleBlock
  '-------------------------------------------------------------------------------
  CATTitleBlockFrame    ' Dessin des traits


  CATTitleBlockStandard ' Representation de la norme de projection


  CATTitleBlockText     ' Creation des textes

End Sub

