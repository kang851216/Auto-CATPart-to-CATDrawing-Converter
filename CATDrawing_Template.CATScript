Sub CATLinks()
  If CATCheckLink = False then exit sub

  '-------------------------------------------------------------------------------
  ' Affichage du nombre de feuille
  '-------------------------------------------------------------------------------
  Dim nbSheet  As Integer
  Dim curSheet As Integer
  nbSheet  = 0
  curSheet = 0

  If (not DrwSheet.IsDetail) Then
    For i = 1 To DrwSheets.Count
      If (not DrwSheets.Item(i).IsDetail) Then
        nbSheet = nbSheet + 1
      End If
    Next
    For i = 1 To DrwSheets.Count
      If (not DrwSheets.Item(i).IsDetail) Then
        On Error Resume Next
        curSheet = curSheet + 1
        DrwSheets.Item(i).Views.Item(2).Texts.GetItem("TitleBlock_Text_Sheet_1").Text = CStr(curSheet) & "/" & CStr(nbSheet)
      End If
    Next
  End If
 
  '-------------------------------------------------------------------------------
  ' Mise a jour de l'echelle
  '------------------------------------------------------------------------------- 
  Dim Echelle As Double
  Dim Denominateur As Integer
  Set Parameter2 = Parameters1.GetItem(Text_41)
  Echelle = DrwSheet.Views.Item(3).Scale
Denominateur = 1
  For N = 1 to 1000
    If Echelle*N = Int(Echelle*N) Then
      Denominateur = N
      Exit For
    End If
  Next

  Parameter2.Value = CStr(Echelle*Denominateur)& ":" & CStr(Denominateur)

  If nbSheet >1 Then

' Modified at 16 Jan 2008: Handle the display for scale is not correct
    'DrwTexts.GetItem("TitleBlock_Text_Scale_1").Text = CStr(DrwSheet.Views.Item(3).Scale)
   DrwTexts.GetItem("TitleBlock_Text_Scale_1").Text = CStr(Echelle*Denominateur)& ":" & CStr(Denominateur)

  Else
    Parameters1.Item(Text_41).Value = DrwTexts.GetItem("TitleBlock_Text_Scale_1").Text
  End If   

  '-------------------------------------------------------------------------------
  ' Mise a jour de la matiere  (Material)
  '-------------------------------------------------------------------------------
  Dim Parameters3D As parameters
  Dim parameter3D  As Parameter
  Dim ProductAnalysis As Analyze
' Modified at 16 Jan 2008: Handle Simplified Chinese Case
  Set Parameters3D = ProductDrawn.Parameters
  For each Parameter3D In Parameters3D
    

If InStr(Parameter3D.Name,"Material") > 0 or InStr(Parameter3D.Name,"材料") > 0 and Parameter3D.ValueAsSTring <> "NIL" And Parameter3D.ValueAsSTring <> "NIL" Then
      Parameters1.Item(Text_43).value = Parameter3D.ValueAsString
      Exit For
    End If
  Next

  If Parameters1.Item(Text_43).ValueAsString = Text_24 or Parameters1.Item(Text_43).ValueAsString = "NIL" Then
    Parameters1.Item(Text_43).value = "NIL"
  End If

  If (Right(ProductDrawn.Parent.Name, 4) = "duct") Then
    Parameters1.Item(Text_43).value = "NIL"
  Else

  '-------------------------------------------------------------------------------
  ' Mise a jour de la masse   Faire un TEST le paramètre est calculé et mis a jour si part, sinon il est libre (The mass display)
  '-------------------------------------------------------------------------------  
    Set ProductAnalysis = ProductDrawn.Analyze
    DrwTexts.GetItem("TitleBlock_Text_Weight_1").Text = FormatNumber(ProductAnalysis.Mass,1)
    Parameters1.Item(Text_42).Value = FormatNumber(ProductAnalysis.Mass,1)
  End If

  '-------------------------------------------------------------------------------
  ' Mise a jour du titre
  '-------------------------------------------------------------------------------
  Dim position as Integer
  position = 1

  Dim product_name As String
 dim revision as string
  Dim tmpproduct_name As String
dim Definition as String
dim Part_name as String

  product_name = ProductDrawn.PartNumber
tmpproduct_name = ProductDrawn.PartNumber
 revision=ProductDrawn.Revision    
Definition=  ProductDrawn.Definition 
 Part_name=  ProductDrawn.DescriptionRef 
  dim h as integer


  position = InStr(1, product_name, "-")
If product_name <> Text_09 then
	If Parameters1.Item(Text_46).value = Text_27 And Parameters1.Item(Text_47).value = Text_28  then

		if position > 0 and position < len(product_name) then
			position = InStr(position + 1, product_name, "-")
'			position = InStr(position + 1, product_name, "-")
		end if
    
		if position > 0 and position < len(product_name) then
    		Parameters1.Item(Text_47).value = Mid(product_name , 1, position - 1)
    		Parameters1.Item(Text_46).value =tmpproduct_name' Mid(product_name , position + 1, len(product_name) - position)
            
else
    		Parameters1.Item(Text_47).value = tmpproduct_name
    		Parameters1.Item(Text_46).value = tmpproduct_name
            
		end if
	End If
 End If

	
    		
Parameters1.Item(Text_52).value = "A"
Parameters1.Item(Text_113).value = Definition
Parameters1.Item(Text_114).value = Part_name
Set ProductAnalysis = ProductDrawn.Analyze
DrwTexts.GetItem("TitleBlock_Text_Weight_1").Text = FormatNumber(ProductAnalysis.Mass,1)
Parameters1.Item(Text_42).Value =FormatNumber(ProductAnalysis.Mass,1)

End Sub

