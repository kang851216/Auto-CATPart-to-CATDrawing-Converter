Sub CATRevisionBlock()
  '-------------------------------------------------------------------------------
  'How to draw the revision block geometry
  '-------------------------------------------------------------------------------
  colRev(1) = -190
  colRev(2) = -175
  colRev(3) = -170
  colRev(4) = -169
  colRev(5) = -150

  On Error Resume Next

  If (revision = 0) Then
    Set Ligne = Fact.CreateLine(OH + colRev(1), hauteur - marge, OH + colRev(1), hauteur - marge - RevRowHauteur)
    Ligne.Name = "Frame_revisionBlock_Column_1" 
    Set Ligne = Fact.CreateLine(OH + colRev(2), hauteur - marge, OH + colRev(2), hauteur - marge - RevRowHauteur)
    Ligne.Name = "Frame_revisionBlock_Column_2"
    Set Ligne = Fact.CreateLine(OH + colRev(4), hauteur - marge, OH + colRev(4), hauteur - marge - RevRowHauteur)
    Ligne.Name = "Frame_revisionBlock_Column_4"
    Set Ligne = Fact.CreateLine(OH + colRev(5), hauteur - marge, OH + colRev(5), hauteur - marge - RevRowHauteur)
    Ligne.Name = "Frame_revisionBlock_Column_5" 
    Set Ligne = Fact.CreateLine(OH + colRev(1), hauteur - marge - RevRowHauteur, OH + colRev(5), hauteur - marge - RevRowHauteur)
    Ligne.Name = "Frame_revisionBlock_Ligne_1" 
    Set Ligne = Fact.CreateLine(OH + colRev(1), hauteur - marge - 2*RevRowHauteur, OH            , hauteur - marge - 2*RevRowHauteur)
    Ligne.Name = "Frame_revisionBlock_Ligne_2" 
    Set Ligne = Fact.CreateLine(OH + colRev(1), hauteur - marge - RevRowHauteur, OH + colRev(1), hauteur - marge - 2*RevRowHauteur)
    Ligne.Name = "Frame_revisionBlock_Column_1_ligne2" 
    Set Ligne = Fact.CreateLine(OH + colRev(3), hauteur - marge - RevRowHauteur, OH + colRev(3), hauteur - marge - 2*RevRowHauteur)
    Ligne.Name = "Frame_revisionBlock_Column_3" 
    Set Ligne = Fact.CreateLine(OH + colRev(5), hauteur - marge - RevRowHauteur, OH + colRev(5), hauteur - marge - 2*RevRowHauteur)
    Ligne.Name = "Frame_revisionBlock_Column_5_ligne2" 
  Else
    Set Ligne = Fact.CreateLine(OH + colRev(1), hauteur - marge- (2*revision)*RevRowHauteur, OH + colRev(1), hauteur - marge - (2*revision+1)*RevRowHauteur)
    Ligne.Name = ("Frame_revisionBlock_Column_1_"+ Chr(65 + revision)) 
    Set Ligne = Fact.CreateLine(OH + colRev(2), hauteur - marge- (2*revision)*RevRowHauteur, OH + colRev(2), hauteur - marge - (2*revision+1)*RevRowHauteur)
    Ligne.Name =( "Frame_revisionBlock_Column_2_"+ Chr(65 + revision))
    Set Ligne = Fact.CreateLine(OH + colRev(4), hauteur - marge- (2*revision)*RevRowHauteur, OH + colRev(4), hauteur - marge - (2*revision+1)*RevRowHauteur)
    Ligne.Name = ("Frame_revisionBlock_Column_4_"+ Chr(65 + revision))
    Set Ligne = Fact.CreateLine(OH + colRev(5), hauteur - marge- (2*revision)*RevRowHauteur, OH + colRev(5), hauteur - marge - (2*revision+1)*RevRowHauteur)
    Ligne.Name = ("Frame_revisionBlock_Column_5_"+ Chr(65 + revision))
 
    Set Ligne = Fact.CreateLine(OH + colRev(1), hauteur - marge - (2*revision+1)*RevRowHauteur, OH + colRev(5), hauteur - marge -(2*revision+1)*RevRowHauteur)
    Ligne.Name = ("Frame_revisionBlock_Ligne_1_"+ Chr(65 + revision)) 
    Set Ligne = Fact.CreateLine(OH + colRev(1), hauteur - marge - (2*revision+2)*RevRowHauteur, OH           , hauteur - marge -(2*revision+2)*RevRowHauteur)
    Ligne.Name = ("Frame_revisionBlock_Ligne_2_"+ Chr(65 + revision)) 

    Set Ligne = Fact.CreateLine(OH + colRev(1), hauteur - marge - (2*revision+1)*RevRowHauteur, OH + colRev(1), hauteur - marge - (2*revision+2)*RevRowHauteur)
    Ligne.Name =("Frame_revisionBlock_Column_1_ligne2_"+ Chr(65 + rev)) 
    Set Ligne = Fact.CreateLine(OH + colRev(3), hauteur - marge - (2*revision+1)*RevRowHauteur, OH + colRev(3), hauteur - marge - (2*revision+2)*RevRowHauteur)
    Ligne.Name = ("Frame_revisionBlock_Column_3_"+ Chr(65 + revision)) 
    Set Ligne = Fact.CreateLine(OH + colRev(5), hauteur - marge - (2*revision+1)*RevRowHauteur, OH + colRev(5), hauteur - marge - (2*revision+2)*RevRowHauteur)
    Ligne.Name = ("Frame_revisionBlock_Column_5_ligne2_"+ Chr(65 + revision)) 

  End If
  If Err.Number <> 0 Then
    Err.Clear
  End If
  On Error Goto 0
End Sub
  
Function CATRevisionBlockText(Description)

  '-------------------------------------------------------------------------------
  'How to fill in the revision block
  '-------------------------------------------------------------------------------

  User = CATIA.SystemService.Environ("LOGNAME")
  If (User = "") Then
    User = CATIA.SystemService.Environ("USERNAME")
  End If

  rev= catcheckrev

  If (revision = 0) Then

    Set TableauModif = Tableaux.Add( OH + colRev(5), hauteur - marge , 1, 1, 2*RevRowHauteur, -50 )
    TableauModif.AnchorPoint = catTableTopLeft
    TableauModif.SetCellBorderType 1, 1, CatTableNone
    TableauModif.SetCellString 1, 1, Description
    TableauModif.SetCellAlignment 1, 1, catTableMiddleCenter
    TableauModif.Name = ("RevisionBlock_Text_description_"+ Chr(65)) 
    TableauModif.SetColumnsize 1, 150
    Set Text = TableauModif.GetCellObject(1, 1)
    Text.SetFontSize 0, 0, 2.5
'    Text.SetFontName 0, 0, "Arial (TrueType)"
    Text.SetFontName 0, 0, "SimSun (TrueType)"
  

    Set Text = DrwTexts.Add(Text_23        , OH + .5*(colRev(1)+colRev(2)), hauteur - marge - .5*RevRowHauteur)
    CATFormatTBText "RevisionBlock_Text_1"          , catMiddleCenter, 1.8
    Set Text = DrwTexts.Add(Chr(65 + revision)        ,      OH + .5*(colRev(4)+colRev(2)), hauteur - marge - .5*RevRowHauteur)
    CATFormatTBText "RevisionBlock_Text_Rev_1"          , catMiddleCenter, 1.8
	'msgbox date
    Set Text = DrwTexts.Add(date        ,      OH + .5*(colRev(4)+colRev(5)), hauteur - marge - .5*RevRowHauteur)
   ' msgbox Text
    CATFormatTBText "RevisionBlock_Text_date_1"          , catMiddleCenter, 1.8
    Set Text = DrwTexts.Add(User        ,      OH + .5*(colRev(1)+colRev(3)), hauteur - marge - 1.5*RevRowHauteur)
    CATFormatTBText "RevisionBlock_Text_user_1"          , catMiddleCenter, 1.8

    Set Text = DrwTexts.Add(Text_24        ,      OH + .5*(colRev(3)+colRev(5)), hauteur - marge - 1.5*RevRowHauteur)
'trial line by cpw on 080414
'    Set Text = DrwTexts.Add(Text_24        ,      OH + .5*(colRev(4)+colRev(5)), hauteur - marge - 1.5*RevRowHauteur)
    CATFormatTBText "RevisionBlock_Text_verif_1"          , catMiddleCenter, 0.8

  else

    Set TableauModif = Tableaux.Add(  OH + colRev(5) , hauteur - marge - (2*revision)*RevRowHauteur, 1, 1, 2*RevRowHauteur, -50 )
    TableauModif.AnchorPoint = catTableTopLeft
    TableauModif.SetCellBorderType 1, 1, CatTableNone
    TableauModif.SetCellString 1, 1, Description
    TableauModif.SetCellAlignment 1, 1, catTableMiddleCenter
    TableauModif.Name = ("RevisionBlock_Text_description_"+ Chr(65 + rev)) 
    TableauModif.SetColumnsize 1, 150
    Hrev = TableauModif.GetRowSize(1)
    TableauModif.SetRowSize 1, Hrev
    Set Text = TableauModif.GetCellObject(1, 1)
    Text.SetFontSize 0, 0, 2.5


    Set Text = DrwTexts.Add(Text_23        , OH + .5*(colRev(1)+colRev(2)), hauteur - marge - (.5+2*revision)*RevRowHauteur )
    CATFormatTBText ("RevisionBlock_Text_"+ Chr(65 + revision))         , catMiddleCenter, 1.8

    Set Text = DrwTexts.Add(Chr(65 + rev)        ,      OH + .5*(colRev(4)+colRev(2)),hauteur - marge - (.5+2*revision)*RevRowHauteur )
    CATFormatTBText ("RevisionBlock_Text_Rev_" +Chr(65 + revision))     , catMiddleCenter, 1.8
	
	'msgbox date

    Set Text = DrwTexts.Add(date        ,      OH + .5*(colRev(4)+colRev(5)), hauteur - marge - (.5+2*revision)*RevRowHauteur )
    CATFormatTBText ("RevisionBlock_Text_date_" +Chr(65 + revision))    , catMiddleCenter, 1.8
	'msgbox Text

    Set Text = DrwTexts.Add(User        ,      OH + .5*(colRev(1)+colRev(3)), hauteur - marge - (1.5+2*revision)*RevRowHauteur )
    CATFormatTBText ("RevisionBlock_Text_user_" + Chr(65 + rev))   , catMiddleCenter, 1.8


    Set Text = DrwTexts.Add(Text_24        ,      OH + .5*(colRev(3)+colRev(5)), hauteur - marge - (1.5+2*revision)*RevRowHauteur )
'trial line by cpw on 080414
'    Set Text = DrwTexts.Add(Text_24        ,      OH + .5*(colRev(4)+colRev(5)), hauteur - marge - (1.5+2*revision)*RevRowHauteur )
    CATFormatTBText ("RevisionBlock_Text_verif_" + Chr(65 + revision))   , catMiddleCenter, 0.8

  End If


  If Err.Number <> 0 Then
    Err.Clear
  End If
  On Error Goto 0
End Function


