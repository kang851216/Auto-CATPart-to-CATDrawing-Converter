Sub CATMoveReference()
  '-------------------------------------------------------------------------------
  ' Deplacer le texte de reference
  '-------------------------------------------------------------------------------
  On Error Resume Next
   Set Text = DrwTexts.GetItem("Reference_" + MacroID)
   If Err.Number <> 0 Then
     Err.Clear
     TranslationX = .0
     TranslationY = .0
     Exit Sub
   End If
  On Error Goto 0

  TranslationX = Largeur - Marge - Text.x
  TranslationY = Hauteur - Marge - Text.y
  Text.x = Text.x + TranslationX
  Text.y = Text.y + TranslationY

End Sub

Sub CATMoveTitleBlock()
  '-------------------------------------------------------------------------------
  ' Translation du cartouche après changement de format
  '-------------------------------------------------------------------------------
  Dim rootName As String
  Dim rootNameLength As Integer
  Dim NbLigneToMove   As Integer
  Dim NbCercleToMove As Integer
  Dim NbTextToMove As Integer
  
  rootName       = "TitleBlock_Text_"
  rootNameLength = Len(rootName)
  NbTextToMove   = DrwTexts.Count
  For i = 1 To NbTextToMove
    Set Text = DrwTexts.Item(i)
    If  (Left(Text.Name, rootNameLength) = rootName) Then
      Text.x = Text.x + TranslationX
      Text.y = Text.y 
    End If
  Next

  j = Catcheckrev

  For revM = 0 To j-1
    Set TableauModif = Tableaux.GetItem("RevisionBlock_Text_description_"+ Chr(65 + revM))
    TableauModif.Move TranslationX, TranslationY
  Next 

  rootName       = "RevisionBlock_Text_"
  rootNameLength = Len(rootName)
  NbTextToMove   = DrwTexts.Count
  For i = 1 To NbTextToMove
    Set Text = DrwTexts.Item(i)
    If  (Left(Text.Name, rootNameLength) = rootName) Then
      Text.x = Text.x + TranslationX
      Text.y = Text.y + TranslationY
    End If
  Next

End Sub

