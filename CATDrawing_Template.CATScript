Sub CATFrame()
  '-------------------------------------------------------------------------------
  ' Dessin du cadre
  '-------------------------------------------------------------------------------
  Dim Cst_1   As Double  ' Longueur (en cm) entre 2 marques horizontales
  Dim Cst_2   As Double  ' Longueur (en cm) entre 2 marques verticales
  Dim Nb_CM_H As Integer ' Nombre/2 de marques horizontales
  Dim Nb_CM_V As Integer ' Nombre/2 de marques verticales
  Dim Regle   As Integer ' Longueur de la regle (en cm)

  CATFrameStandard     Nb_CM_H, Nb_CM_V, Regle, Cst_1, Cst_2

  CATFrameBorder

  CATFrameCentringMark Nb_CM_H, Nb_CM_V, Regle, Cst_1, Cst_2

  CATFrameText         Nb_CM_H, Nb_CM_V, Regle, Cst_1, Cst_2

  CATFrameRuler        Regle, Cst_1

End Sub

Sub CATFrameStandard(Nb_CM_H As Integer, Nb_CM_V As Integer, Regle As Integer, Cst_1 As Double, Cst_2 As Double)
  '-------------------------------------------------------------------------------
  ' Calcul des valeurs standard pour le cadre
  '-------------------------------------------------------------------------------
  Cst_1 = 74.2 '297, 594, 1189 are multiples of 74.2
  Cst_2 = 52.5 '210, 420, 841  are multiples of 52.2
  If DrwSheet.Orientation = CatPaperPortrait And _
     (sheetFormat = CatPaperA0 Or sheetFormat = CatPaperA2 Or sheetFormat = CatPaperA4) Or _
      DrwSheet.Orientation = CatPaperLandscape And _
     (sheetFormat = CatPaperA1 Or sheetFormat = CatPaperA3) Then
    Cst_1 = 52.5
    Cst_2 = 74.2
  End If

  Nb_CM_H = CInt(.5 * Largeur / Cst_1)
  Nb_CM_V = CInt(.5 * Hauteur / Cst_2)

  Regle   = CInt((Nb_CM_H - 1) * Cst_1 / 50) * 100   ' calcul de la logueur maxi de la regle
  If RulerLength < Regle Then
    Regle = RulerLength
  End If
End Sub

Sub CATFrameBorder()
  '-------------------------------------------------------------------------------
  ' Dessin de la bordure du cadre
  '-------------------------------------------------------------------------------
  On Error Resume Next
   Set Ligne = Fact.CreateLine(OV, OV             , OH, OV             )
   Ligne.Name = "Frame_Border_Bottom"
   Set Ligne = Fact.CreateLine(OH, OV             , OH, Hauteur - Marge)
   Ligne.Name = "Frame_Border_Left"
   Set Ligne = Fact.CreateLine(OH, Hauteur - Marge, OV, Hauteur - Marge)
   Ligne.Name = "Frame_Border_Top"
   Set Ligne = Fact.CreateLine(OV, Hauteur - Marge, OV, OV             )
   Ligne.Name = "Frame_Border_Right"
   If Err.Number <> 0 Then
     Err.Clear
   End If
  On Error Goto 0
End Sub

Sub CATFrameCentringMark(Nb_CM_H As Integer, Nb_CM_V As Integer, Regle As Integer, Cst_1 As Double, Cst_2 As Double)
  '-------------------------------------------------------------------------------
  ' Dessin des marques de centrage
  '-------------------------------------------------------------------------------
  On Error Resume Next
   Set Ligne = Fact.CreateLine(.5 * Largeur    , Hauteur - Marge, .5 * Largeur, Hauteur     )
   Ligne.Name = "Frame_CentringMark_Top"
   Set Ligne = Fact.CreateLine(.5 * Largeur    , OV             , .5 * Largeur, .0         )
   Ligne.Name = "Frame_CentringMark_Bottom"
   Set Ligne = Fact.CreateLine(OV            , .5 * Hauteur    , .0        , .5 * Hauteur)
   Ligne.Name = "Frame_CentringMark_Left"
   Set Ligne = Fact.CreateLine(Largeur - Marge, .5 * Hauteur    , Largeur     , .5 * Hauteur)
   Ligne.Name = "Frame_CentringMark_Right"

   For i = Nb_CM_H To Regle/2/Cst_1 Step -1
     If (i * Cst_1 < .5 * Largeur - 1.) Then
       Set Ligne  = Fact.CreateLine(.5 * Largeur + i * Cst_1, OV, .5 * Largeur + i * Cst_1, .25 * Marge)
       Ligne.Name = "Frame_CentringMark_Bottom"
       Set Ligne  = Fact.CreateLine(.5 * Largeur - i * Cst_1, OV, .5 * Largeur - i * Cst_1, .25 * Marge)
       Ligne.Name = "Frame_CentringMark_Bottom"
     End If
   Next

   For i = 1 To Nb_CM_H
     If (i * Cst_1 < .5 * Largeur - 1.) Then
       Set Ligne  = Fact.CreateLine(.5 * Largeur + i * Cst_1, Hauteur - Marge, .5 * Largeur + i * Cst_1, Hauteur - .25 * Marge)
       Ligne.Name = "Frame_CentringMark_Top"
       Set Ligne  = Fact.CreateLine(.5 * Largeur - i * Cst_1, Hauteur - Marge, .5 * Largeur - i * Cst_1, Hauteur - .25 * Marge)
       Ligne.Name = "Frame_CentringMark_Top"
     End If
   Next

   For i = 1 To Nb_CM_V
     If (i * Cst_2 < .5 * Hauteur - 1.) Then
       Set Ligne  = Fact.CreateLine(OV, .5 * Hauteur + i * Cst_2, .25 * Marge        , .5 * Hauteur + i * Cst_2)
       Ligne.Name = "Frame_CentringMark_Left"
       Set Ligne  = Fact.CreateLine(OV, .5 * Hauteur - i * Cst_2, .25 * Marge        , .5 * Hauteur - i * Cst_2)
       Ligne.Name = "Frame_CentringMark_Left"
       Set Ligne  = Fact.CreateLine(OH, .5 * Hauteur + i * Cst_2, Largeur - .25 * Marge, .5 * Hauteur + i * Cst_2)
       Ligne.Name = "Frame_CentringMark_Right"
       Set Ligne  = Fact.CreateLine(OH, .5 * Hauteur - i * Cst_2, Largeur - .25 * Marge, .5 * Hauteur - i * Cst_2)
       Ligne.Name = "Frame_CentringMark_Right"
     End If
   Next

   If Err.Number <> 0 Then
    Err.Clear
   End If
  On Error Goto 0
End Sub

Sub CATFrameText(Nb_CM_H As Integer, Nb_CM_V As Integer, Regle As Integer, Cst_1 As Double, Cst_2 As Double)
  '-------------------------------------------------------------------------------
  ' Creation des textes du cadre
  '-------------------------------------------------------------------------------
  On Error Resume Next

   For i = Nb_CM_H To (Regle/2/Cst_1 + 1) Step -1
     Set Text = DrwTexts.Add(Chr(65 + Nb_CM_H - i) , .5 * Largeur + (i - .5) * Cst_1, .5 * Marge)
     CATFormatFText "Frame_Text_Bottom", 0
     Set Text = DrwTexts.Add(Chr(64 + Nb_CM_H + i) , .5 * Largeur - (i - .5) * Cst_1, .5 * Marge)
     CATFormatFText "Frame_Text_Bottom", 0
   Next
   For i = 1 To Nb_CM_H
     Set Text = DrwTexts.Add(Chr(65 + Nb_CM_H - i), .5 * Largeur + (i - .5) * Cst_1, Hauteur - .5 * Marge)
     CATFormatFText "Frame_Text_Top", -90
     Set Text = DrwTexts.Add(Chr(64 + Nb_CM_H + i), .5 * Largeur - (i - .5) * Cst_1, Hauteur - .5 * Marge)
     CATFormatFText "Frame_Text_Top", -90
   Next

   For i = 1 To Nb_CM_V
     Set Text = DrwTexts.Add(CStr(Nb_CM_V + i)     , .5 * Marge        , .5 * Hauteur + (i - .5) * Cst_2)
     CATFormatFText "Frame_Text_Left", -90
     Set Text = DrwTexts.Add(CStr(Nb_CM_V - i + 1) , .5 * Marge        , .5 * Hauteur - (i - .5) * Cst_2)
     CATFormatFText "Frame_Text_Left", -90
     Set Text = DrwTexts.Add(CStr(Nb_CM_V + i)    , Largeur - .5 * Marge, .5 * Hauteur + (i - .5) * Cst_2)
     CATFormatFText "Frame_Text_Right", 0
     Set Text = DrwTexts.Add(CStr(Nb_CM_V - i + 1), Largeur - .5 * Marge, .5 * Hauteur - (i - .5) * Cst_2)
     CATFormatFText "Frame_Text_Right", 0
   Next

   If Err.Number <> 0 Then
     Err.Clear
   End If
  On Error Goto 0
End Sub

Sub CATFrameRuler(Regle As Integer, Cst_1 As Single)
  '-------------------------------------------------------------------------------
  ' Dessin de la regle
  '-------------------------------------------------------------------------------
  'Frame_Regle_Guide -----------------------------------------------
  'Frame_Regle_1cm   | | | | | | | | | | | | | | | | | | | | | | | |
  'Frame_Regle_5cm   |         |         |         |         |      
  
  On Error Resume Next
   Set Ligne = Fact.CreateLine(.5 * Largeur - Regle/2 , .75 * Marge, .5 * Largeur + Regle/2, .75 * Marge)
   Ligne.Name = "Frame_Regle_Guide"

   For i = 1 To Regle/100
     Set Ligne = Fact.CreateLine(.5 * Largeur - 50 * i, OV, .5 * Largeur - 50 * i, .5 * Marge )
     Ligne.Name = "Frame_Regle_5cm"
     Set Ligne = Fact.CreateLine(.5 * Largeur + 50 * i, OV, .5 * Largeur + 50 * i, .5 * Marge )
     Ligne.Name = "Frame_Regle_5cm"
     For j = 1 To 4
       Set Ligne = Fact.CreateLine(.5 * Largeur - 50 * i + 10 * j, OV, .5 * Largeur - 50 * i + 10 * j, .75 * Marge)
       Ligne.Name = "Frame_Regle_1cm"
       Set Ligne = Fact.CreateLine(.5 * Largeur + 50 * i - 10 * j, OV, .5 * Largeur + 50 * i - 10 * j, .75 * Marge)
       Ligne.Name = "Frame_Regle_1cm"
     Next
   Next

   If Err.Number <> 0 Then
     Err.Clear
   End If
  On Error Goto 0
End Sub

'*****************************************************************************************************************************
'*****************************************************************************************************************************
'*****************************************************************************************************************************

Sub CATTitleBlockStandard()
  '-------------------------------------------------------------------------------
  ' Dessin de la representation de la norme de projection
  '-------------------------------------------------------------------------------
  Dim R1   As Double
  Dim R2   As Double
  Dim X(5) As Double
  Dim Y(7) As Double

  R1   = 1.6
  R2   = 3.2
  X(1) = OH   + Col(11) + 1
  X(2) = X(1) + 2.5
  X(3) = X(1) + 8.5
  X(4) = X(1) + 13
  X(5) = X(1) + 17
 ' Y(1) = OV   + (Row(5)+Row(4))/2.
  Y(1) = OV   + Row(5)
Y(2) = Y(1) + R1
  Y(3) = Y(1) + R2
  Y(4) = Y(1) + 5.5
  Y(5) = Y(1) - R1
  Y(6) = Y(1) - R2
  Y(7) = 2*Y(1) - Y(4)

  If DrwSheet.ProjectionMethod <> CatFirstAngle Then
    X(2) = X(1) + X(5) - X(2)
    X(3) = X(1) + X(5) - X(3)
    X(4) = X(1) + X(5) - X(4)
  End If

  On Error Resume Next
   Set Ligne   = Fact.CreateLine(X(1), Y(1), X(5), Y(1))
   Ligne.Name   = "TitleBlock_Standard_Ligne_Axis_1"
   Set Ligne   = Fact.CreateLine(X(4), Y(7), X(4), Y(4))
   Ligne.Name   = "TitleBlock_Standard_Ligne_Axis_2"
   Set Ligne   = Fact.CreateLine(X(2), Y(5), X(2), Y(2))
   Ligne.Name   = "TitleBlock_Standard_Ligne_1"
   Set Ligne   = Fact.CreateLine(X(2), Y(2), X(3), Y(3))
   Ligne.Name   = "TitleBlock_Standard_Ligne_2"
   Set Ligne   = Fact.CreateLine(X(3), Y(3), X(3), Y(6))
   Ligne.Name   = "TitleBlock_Standard_Ligne_3"
   Set Ligne   = Fact.CreateLine(X(3), Y(6), X(2), Y(5))
   Ligne.Name   = "TitleBlock_Standard_Ligne_4"
   Set Cercle = Fact.CreateClosedCircle(X(4), Y(1), R1)
   Cercle.Name = "TitleBlock_Standard_Cercle_1"
   Set Cercle = Fact.CreateClosedCircle(X(4), Y(1), R2)
   Cercle.Name = "TitleBlock_Standard_Cercle_2"
 If Err.Number <> 0 Then
   Err.Clear 
 End If
 On Error Goto 0
End Sub

Sub CATRemoveStandard()
  '-------------------------------------------------------------------------------
  ' Effacement de la representation de la norme de projection
  '-------------------------------------------------------------------------------
  On Error Resume Next
   Selection.Clear
   selection.Add(DrwView)
   selection.Search "(Name=TitleBlock_Standard_* & CATDrwSearch.2DGeometry),all"
   If Err.Number <> 0 Then
     Err.Clear
   else
     Selection.Delete
   End If
  On Error Goto 0
End Sub

'*****************************************************************************************************************************


Sub CATFormatFText(textName As String, angle As Double)
  '-------------------------------------------------------------------------------
  ' Format des textes du cadre (Format of the texts of the frame)
  '-------------------------------------------------------------------------------
  Text.Name           = textName
  Text.AnchorPosition = CATMiddleCenter
  Text.Angle          = angle
End Sub


Sub CATFormatTBText(textName As String, anchorPosition As String, fontSize)
  '-------------------------------------------------------------------------------
  ' Format des textes du cartouche (Format of the texts of the cartouche)
  '-------------------------------------------------------------------------------
  Text.Name           = textName
  'Text.SetFontName      0, 0, "Monospac821 BT"
'  Text.SetFontName      0, 0, "Arial (TrueType)"
'  Text.SetFontName 0, 0, "SimSun (TrueType)"
    Text.SetFontName 0, 0, "YouYuan (TrueType)"
  Text.AnchorPosition = anchorPosition
  Text.SetFontSize      0, 0, fontSize
End Sub


Sub CATFormatRBText(textName As String, anchorPosition As String)
  '-------------------------------------------------------------------------------
  ' Format des textes du cartouche à la taille de 3.5 (Format of the texts of the cartouche in the size of 3.5)
  '-------------------------------------------------------------------------------
  Text.Name           = textName
  Text.AnchorPosition = anchorPosition
  Text.SetFontSize      0, 0, 3.5
End Sub


Sub CATFormatLOGOText(textName As String, anchorPosition As String, fontSize)
  '-------------------------------------------------------------------------------
  ' Format des textes du cartouche (Format of the texts of the cartouche)
  '-------------------------------------------------------------------------------
  Text.Name           = textName
  Text.SetFontName      0, 0, "Franklin Gothic Medium"
  Text.AnchorPosition = anchorPosition
  Text.SetFontSize      0, 0, fontSize
End Sub


Sub CATFormatRATIOText(textName As String, anchorPosition As String, ratio, fontSize)
  '-------------------------------------------------------------------------------
  ' Format des textes du cartouche  (Format of the texts of the cartouche)
  '-------------------------------------------------------------------------------
  Text.Name           = textName
  Text.SetFontName      0, 0, "Monospac821 BT"
  Text.AnchorPosition = anchorPosition
  Text.SetFontSize      0, 0, fontSize
  Text.Ratio           = ratio 
End Sub